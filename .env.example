# Configuración de la API MundoDonghua

# Puerto del servidor
PORT=3000

# URL base de MundoDonghua
MUNDODONGHUA_BASE_URL=https://www.mundodonghua.com/

# User-Agent para las peticiones (obligatorio para evitar error 403)
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# Configuración de caché (opcional - para implementación futura)
# CACHE_ENABLED=true
# CACHE_TTL=3600

# Rate limiting (opcional - para implementación futura)
# RATE_LIMIT_WINDOW=15
# RATE_LIMIT_MAX_REQUESTS=100
